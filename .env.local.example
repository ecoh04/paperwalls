# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to git — it contains secrets.

# Supabase (database)
# Get these from: Supabase Dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase service role key (only for server-side admin tasks; keep secret)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PayFast (payments – South Africa). From your PayFast dashboard.
# PAYFAST_MERCHANT_ID=10000100
# PAYFAST_MERCHANT_KEY=xxxxxxxxxxxx
# PAYFAST_PASSPHRASE=your-passphrase   # if set in PayFast settings
# PAYFAST_SANDBOX=true                 # set to false in production

# App URL – no trailing slash. Production: https://paperwalls.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
